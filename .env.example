# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=satellite_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/satellite_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Node.js Environment
NODE_ENV=development
PORT=5000

# JWT Secret (Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# NASA API
NASA_API_KEY=your_nasa_api_key_here

# OpenWeatherMap API
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Mapbox Token (for enhanced maps)
REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# Copernicus Hub (Optional - for advanced satellite data)
COPERNICUS_USERNAME=your_copernicus_username
COPERNICUS_PASSWORD=your_copernicus_password

# Frontend API URL
REACT_APP_API_URL=http://localhost:5000

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Logging
LOG_LEVEL=info
